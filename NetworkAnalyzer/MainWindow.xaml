<Window x:Class="NetworkAnalyzer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Анализатор сетевых подключений" Height="700" Width="1000"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="200"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Анализатор сетевых подключений"
                   FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>

        <!-- Левая панель: список интерфейсов -->
        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,10,0">
            <TextBlock Text="Сетевые интерфейсы:" FontWeight="Bold" Margin="0,0,0,5"/>
            <Button Content="Обновить список" Click="RefreshInterfaces_Click" Margin="0,0,0,5" Padding="5"/>
            <ListBox x:Name="InterfacesList" Height="300"
                     SelectionChanged="InterfacesList_SelectionChanged"
                     DisplayMemberPath="Name"/>
            <TextBlock Text="Информация об интерфейсе:" FontWeight="Bold" Margin="0,10,0,5"/>
            <TextBox x:Name="InterfaceInfoBox" Height="200"
                     IsReadOnly="True" VerticalScrollBarVisibility="Auto"
                     TextWrapping="Wrap" FontFamily="Consolas" FontSize="12"/>
        </StackPanel>

        <!-- Правая панель: URL анализ -->
        <StackPanel Grid.Row="1" Grid.Column="1">
            <TextBlock Text="Анализ URL / проверка хоста:" FontWeight="Bold" Margin="0,0,0,5"/>
            <DockPanel Margin="0,0,0,5">
                <Button DockPanel.Dock="Right" Content="Анализировать" Click="AnalyzeUrl_Click"
                        Padding="10,5" Margin="5,0,0,0"/>
                <TextBox x:Name="UrlInput" Text="https://www.example.com/path?q=1&amp;page=2#section"
                         VerticalContentAlignment="Center" Padding="5"/>
            </DockPanel>
            <DockPanel Margin="0,0,0,5">
                <Button DockPanel.Dock="Right" Content="Ping + DNS" Click="PingHost_Click"
                        Padding="10,5" Margin="5,0,0,0"/>
                <TextBox x:Name="PingHostInput" Text="google.com"
                         VerticalContentAlignment="Center" Padding="5"/>
            </DockPanel>
            <TextBlock Text="Результаты анализа:" FontWeight="Bold" Margin="0,5,0,5"/>
            <TextBox x:Name="ResultsBox" Height="300"
                     IsReadOnly="True" VerticalScrollBarVisibility="Auto"
                     TextWrapping="Wrap" FontFamily="Consolas" FontSize="12"
                     Background="#F8F8F8"/>
        </StackPanel>

        <!-- История проверенных URL -->
        <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,10,0,5">
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="Очистить историю" Click="ClearHistory_Click" Padding="10,3"/>
                <TextBlock Text="История проверенных URL:" FontWeight="Bold" VerticalAlignment="Center"/>
            </DockPanel>
        </StackPanel>
        <ListBox x:Name="HistoryList" Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                 SelectionChanged="HistoryList_SelectionChanged"/>
    </Grid>
</Window>
